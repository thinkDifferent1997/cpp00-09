NAME = ScalarConverter

CXX = c++

FLAGS = -Wall -Wextra -Werror -std=c++98

SRC = main.cpp  ScalarConverter

OBJ = $(SRC:.cpp=.o)

all: $(NAME)

$(NAME): $(OBJ)
	$(CXX) $(FLAGS) -o $(NAME) $(OBJ)

clean:
	rm -f $(OBJ)

fclean:
	rm -f $(NAME)
	rm -f $(OBJ)

re: fclean all

.PHONY: all clean fclean re